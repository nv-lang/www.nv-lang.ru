---
import BaseLayout from '@layouts/BaseLayout.astro';
import body from '@partials/blog-index.html?raw';
const meta = {
  title: "Blog — Nova",
  description: "The Nova language blog: announcements, design notes, and development updates.",
  canonical: "https://nv-lang.org/blog/",
  lang: "en" as const,
  hreflangRu: "https://nv-lang.org/ru/blog/",
  hreflangEn: "https://nv-lang.org/blog/",
  hreflangXDefault: "https://nv-lang.org/blog/",
  ogType: "website",
  ogUrl: "https://nv-lang.org/blog/",
  ogTitle: "Blog — Nova",
  ogDescription: "The Nova language blog: announcements, design notes, and development updates.",
  twitterTitle: "Blog — Nova",
  twitterDescription: "The Nova language blog: announcements, design notes, and development updates.",
  langRuUrl: "/ru/blog/",
  langEnUrl: "/blog/",
};
---

<BaseLayout {...meta} active="blog">
  <Fragment set:html={body} />
</BaseLayout>
