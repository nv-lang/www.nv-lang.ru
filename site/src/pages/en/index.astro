---
// /en/ — редирект на английскую главную (/). noindex: в индекс не попадает.
// Сохранён ради старых внешних ссылок на /en/ (до унификации языковой схемы
// /en/ был адресом английской главной). Самостоятельная страница без BaseLayout.
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" href="/favicon.svg" />
    <meta http-equiv="refresh" content="0;url=/" />
    <meta name="robots" content="noindex" />
    <link rel="canonical" href="https://nv-lang.org/" />
    <title>Nova — redirecting…</title>
  </head>
  <body>
    <p>Redirecting… <a href="/">go to the homepage</a></p>
  </body>
</html>
