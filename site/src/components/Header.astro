---
// Header — общая шапка сайта. Заменяет 28 ручных копий.
// lang-switch выводится только если переданы обе ссылки (на 404 его нет).
interface Props {
  lang: 'ru' | 'en';
  active?: 'home' | 'install' | 'doc' | 'spec' | 'blog' | 'search';
  langRuUrl?: string; // ссылка lang-switch на RU-версию
  langEnUrl?: string; // ссылка lang-switch на EN-версию
}
const { lang, active, langRuUrl, langEnUrl } = Astro.props;
const showLangSwitch = Boolean(langRuUrl && langEnUrl);

const t = lang === 'ru'
  ? {
      labels: { home: 'Главная', install: 'Установка', doc: 'Doc', spec: 'Spec', blog: 'Blog', search: 'Поиск' },
      urls: { home: '/ru/', install: '/ru/install/', doc: '/ru/doc/', spec: '/ru/spec/', blog: '/ru/blog/', search: '/ru/search/' },
      logo: '/ru/', nav: 'Основная', toggle: 'Навигация', langLabel: 'Язык',
    }
  : {
      labels: { home: 'Home', install: 'Install', doc: 'Doc', spec: 'Spec', blog: 'Blog', search: 'Search' },
      urls: { home: '/', install: '/install/', doc: '/doc/', spec: '/spec/', blog: '/blog/', search: '/search/' },
      logo: '/', nav: 'Main', toggle: 'Toggle navigation', langLabel: 'Language',
    };
const items = ['home', 'install', 'doc', 'spec', 'blog', 'search'] as const;
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="site-logo" href={t.logo} aria-label="Nova"><img src="/logo.svg" alt="Nova" /></a>
    <button
      class="nav-toggle"
      aria-label={t.toggle}
      onclick="this.closest('header').querySelector('.site-nav').classList.toggle('open')"
    >
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="5" x2="17" y2="5" />
        <line x1="3" y1="10" x2="17" y2="10" />
        <line x1="3" y1="15" x2="17" y2="15" />
      </svg>
    </button>
    <nav class="site-nav" aria-label={t.nav}>
      {items.map((it) => (
        <a href={t.urls[it]} class={active === it ? 'active' : undefined}>{t.labels[it]}</a>
      ))}
    </nav>
    <div class="site-header__right">
      {showLangSwitch && (
        <div class="lang-switch" aria-label={t.langLabel}>
          <a href={langRuUrl} class={lang === 'ru' ? 'active' : undefined}>RU</a>
          <a href={langEnUrl} class={lang === 'en' ? 'active' : undefined}>EN</a>
        </div>
      )}
      <a
        href="https://github.com/nv-lang/nova"
        class="btn btn-outline"
        style="padding:.3rem .75rem;font-size:.83rem;"
        aria-label="GitHub"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
        GitHub
      </a>
    </div>
  </div>
</header>
