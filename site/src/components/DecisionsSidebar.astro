---
// Боковая навигация раздела решений (/spec/decisions/).
import { TOPICS } from '@data/decisions';

interface Props {
  current?: string; // 'index' или slug раздела
}
const { current } = Astro.props;
---

<aside class="doc-sidebar">
  <div class="sidebar-section">
    <div class="sidebar-section__title">Решения</div>
    <ul>
      <li>
        <a href="/spec/decisions/" class={current === 'index' ? 'active' : undefined}>
          Все D-блоки
        </a>
      </li>
    </ul>
  </div>
  <div class="sidebar-section">
    <div class="sidebar-section__title">Разделы</div>
    <ul>
      {TOPICS.map((t) => (
        <li>
          <a href={`/spec/decisions/${t.slug}/`} class={current === t.slug ? 'active' : undefined}>
            {t.title}
          </a>
        </li>
      ))}
    </ul>
  </div>
  <div class="sidebar-section">
    <div class="sidebar-section__title">Ещё</div>
    <ul>
      <li><a href="/ru/spec/">Спецификация</a></li>
      <li><a href="https://github.com/nv-lang/nova/tree/main/spec/decisions">Источник на GitHub</a></li>
    </ul>
  </div>
</aside>
