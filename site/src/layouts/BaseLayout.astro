---
// BaseLayout — единый каркас страницы: <html>, <head>, шапка, подвал,
// скрипт подсветки. Контент страницы приходит в default-слот.
import '../styles/global.css';
import Head from '../components/Head.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  canonical: string;
  lang: 'ru' | 'en';
  hreflangRu?: string;
  hreflangEn?: string;
  hreflangXDefault?: string;
  ogType?: string;
  ogUrl?: string;
  ogTitle?: string;
  ogDescription?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  jsonLd?: boolean;
  noindex?: boolean;
  active?: 'home' | 'install' | 'doc' | 'spec' | 'blog' | 'search';
  customFooter?: boolean;
  langRuUrl?: string;
  langEnUrl?: string;
}
const p = Astro.props;
const { lang, active, customFooter = false } = p;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <Head {...p} />
    <slot name="head-extra" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header lang={lang} active={active} langRuUrl={p.langRuUrl} langEnUrl={p.langEnUrl} />
    <div data-pagefind-body><slot /></div>
    {!customFooter && <Footer lang={lang} />}
    <script src="/js/nova-highlight.js" is:inline></script>
    <script src="/js/copy-code.js" is:inline></script>
    <script src="/js/scroll-spy.js" is:inline></script>
  </body>
</html>
